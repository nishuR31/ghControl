# ── GitHub ────────────────────────────────────────────────────────
# Your GitHub Personal Access Token (stored in localStorage on client)
# For server-side webhook secret:
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gh-control

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change_this_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
