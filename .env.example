# ── GitHub ────────────────────────────────────────────────────────
# Your GitHub Personal Access Token (stored in localStorage on client)
# For server-side webhook secret:
GITHUB_WEBHOOK_SECRET=

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=
# Optional: force TLS on/off regardless of URL scheme
# REDIS_TLS=true
# Optional (for managed providers with self-signed cert chains)
# REDIS_TLS_REJECT_UNAUTHORIZED=false
# App activity log key/size
# REDIS_ACTIVITY_KEY=gh:activity:app
# REDIS_ACTIVITY_LIMIT=200
# ── App ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=

# ── Logging Policy ─────────────────────────────────────────────────
# Store compact gzip app-action logs in MongoDB (repo create, issue create, etc.)
# MONGO_ACTIVITY_ENABLED=true
# Keep external webhook payload logging OFF by default
# LOG_EXTERNAL_WEBHOOKS=false
# Optional: enable worker-level Mongo JobLog writes (default OFF)
# WORKER_MONGO_LOG=false
